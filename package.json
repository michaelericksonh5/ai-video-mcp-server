{
  "name": "veo-video-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for AI video generation — Veo 3.1 (fal.ai + Gemini), Happy Horse, and Seedance 2.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "veo-video-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "video-generation",
    "veo",
    "veo3.1",
    "fal-ai",
    "gemini",
    "happy-horse",
    "seedance",
    "ai-video",
    "claude-plugin"
  ],
  "license": "MIT",
  "dependencies": {
    "@fal-ai/client": "^1.5.0",
    "@google/genai": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
